---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const formattedDate = new Date(post.data.date + 'T00:00:00').toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<Layout
  title={`${post.data.title} — Paperclip Blog`}
  description={post.data.excerpt}
  ogImage={post.data.youtubeId ? `https://i.ytimg.com/vi/${post.data.youtubeId}/maxresdefault.jpg` : post.data.coverImage}
>
  <div class="blog-post-page">
    <Navbar />

    <article class="blog-post">
      <header class="blog-post-header">
        <div class="container">
          <a href="/blog" class="blog-back-link">&larr; Back to blog</a>
          <div class="blog-post-meta">
            <time datetime={post.data.date}>{formattedDate}</time>
            <span class="blog-post-author">By {post.data.author}</span>
            {post.data.tags.map((tag) => (
              <span class="blog-post-tag">{tag}</span>
            ))}
          </div>
          <h1 class="heading-serif blog-post-title">{post.data.title}</h1>
          <p class="blog-post-excerpt">{post.data.excerpt}</p>
        </div>
      </header>

      {post.data.youtubeId && (
        <div class="container">
          <div class="blog-post-video">
            <iframe
              src={`https://www.youtube.com/embed/${post.data.youtubeId}`}
              title={post.data.title}
              frameborder="0"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
              allowfullscreen
            />
          </div>
        </div>
      )}

      <div class="container">
        <div class="blog-post-content">
          <Content />
        </div>
      </div>
    </article>

    <Footer />
  </div>
</Layout>

<style>
  .blog-post-page {
    background: var(--color-bg);
  }

  /* ── Header ── */
  .blog-post-header {
    padding-top: clamp(8rem, 12vw, 11rem);
    padding-bottom: var(--space-lg);
    background: #1a1a2e;
  }

  .blog-back-link {
    display: inline-block;
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.5);
    margin-bottom: var(--space-md);
    transition: color 0.2s;
  }

  .blog-back-link:hover {
    color: #fff;
  }

  .blog-post-meta {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.75rem;
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.5);
    margin-bottom: var(--space-sm);
  }

  .blog-post-author {
    color: rgba(255, 255, 255, 0.72);
  }

  .blog-post-tag {
    font-size: 0.7rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: rgba(255, 255, 255, 0.7);
    background: rgba(255, 255, 255, 0.1);
    padding: 0.2em 0.65em;
    border-radius: var(--radius-pill);
  }

  .blog-post-title {
    font-size: clamp(2rem, 4.5vw, 3rem);
    margin-bottom: 0.75rem;
    max-width: 720px;
    color: #fff;
  }

  .blog-post-excerpt {
    font-size: 1.1rem;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.6);
    max-width: 620px;
  }

  /* ── Video embed ── */
  .blog-post-video {
    position: relative;
    width: 100%;
    max-width: 840px;
    aspect-ratio: 16 / 9;
    border-radius: var(--radius);
    overflow: hidden;
    background: var(--color-surface);
    margin-bottom: var(--space-xl);
  }

  .blog-post-video iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: none;
  }

  /* ── Prose content ── */
  .blog-post-content {
    max-width: 680px;
    padding-bottom: var(--space-3xl);
  }

  .blog-post-content :global(h2) {
    font-family: var(--font-serif);
    font-size: 1.6rem;
    font-weight: 400;
    margin-top: var(--space-xl);
    margin-bottom: var(--space-sm);
    color: var(--color-text);
  }

  .blog-post-content :global(h3) {
    font-family: var(--font-sans);
    font-size: 1.15rem;
    font-weight: 600;
    margin-top: var(--space-lg);
    margin-bottom: 0.5rem;
    color: var(--color-text);
  }

  .blog-post-content :global(p) {
    font-size: 1.05rem;
    line-height: 1.7;
    color: var(--color-text-secondary);
    margin-bottom: var(--space-sm);
  }

  .blog-post-content :global(ul),
  .blog-post-content :global(ol) {
    padding-left: 1.5rem;
    margin-bottom: var(--space-sm);
  }

  .blog-post-content :global(ul) {
    list-style: disc;
  }

  .blog-post-content :global(ol) {
    list-style: decimal;
  }

  .blog-post-content :global(li) {
    font-size: 1.05rem;
    line-height: 1.7;
    color: var(--color-text-secondary);
    margin-bottom: 0.35rem;
  }

  .blog-post-content :global(strong) {
    font-weight: 600;
    color: var(--color-text);
  }

  .blog-post-content :global(a) {
    color: var(--color-text);
    text-decoration: underline;
    text-underline-offset: 2px;
    transition: color 0.2s;
  }

  .blog-post-content :global(a:hover) {
    color: var(--color-text-secondary);
  }

  .blog-post-content :global(code) {
    font-family: var(--font-mono);
    font-size: 0.9em;
    background: var(--color-surface);
    padding: 0.15em 0.4em;
    border-radius: 4px;
  }

  .blog-post-content :global(pre) {
    background: var(--color-surface);
    border-radius: var(--radius-sm);
    padding: var(--space-md);
    overflow-x: auto;
    margin-bottom: var(--space-md);
  }

  .blog-post-content :global(pre code) {
    background: none;
    padding: 0;
  }

  .blog-post-content :global(blockquote) {
    border-left: 3px solid var(--color-border);
    padding-left: var(--space-md);
    margin-bottom: var(--space-sm);
    color: var(--color-text-muted);
    font-style: italic;
  }

  .blog-post-content :global(hr) {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: var(--space-xl) 0;
  }
</style>
