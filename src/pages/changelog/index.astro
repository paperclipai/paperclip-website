---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';

const releases = (await getCollection('releases')).sort((a, b) => {
  const va = a.data.version.split('.').map(Number);
  const vb = b.data.version.split('.').map(Number);
  for (let i = 0; i < 3; i++) {
    if (vb[i] !== va[i]) return vb[i] - va[i];
  }
  return 0;
});
---

<Layout title="Changelog — Paperclip" description="Release notes and version history for Paperclip.">
  <Navbar />

  <header class="changelog-header">
    <div class="container">
      <span class="section-badge">Changelog</span>
      <h1 class="heading-serif changelog-title">What's new in Paperclip</h1>
      <p class="text-secondary changelog-subtitle">Release notes, improvements, and upgrade guides.</p>
    </div>
  </header>

  <main class="changelog-main">
    <div class="container">
      <div class="changelog-timeline">
        {releases.map((release) => (
          <a href={`/changelog/v${release.data.version}`} class="changelog-entry">
            <div class="changelog-entry-meta">
              <span class="changelog-version">v{release.data.version}</span>
              {release.data.breaking && (
                <span class="changelog-breaking-badge">Breaking</span>
              )}
            </div>
            <time class="changelog-date" datetime={release.data.date}>
              {new Date(release.data.date + 'T00:00:00').toLocaleDateString('en-US', {
                year: 'numeric',
                month: 'long',
                day: 'numeric',
              })}
            </time>
          </a>
        ))}
      </div>
    </div>
  </main>

  <Footer />
</Layout>

<style>
  .changelog-header {
    padding-top: clamp(8rem, 12vw, 12rem);
    padding-bottom: var(--space-xl);
    background: var(--color-bg);
  }

  .changelog-title {
    font-size: clamp(2.2rem, 5vw, 3.5rem);
    margin-bottom: 0.5rem;
  }

  .changelog-subtitle {
    font-size: 1.1rem;
    max-width: 480px;
  }

  .changelog-main {
    padding-bottom: var(--space-3xl);
  }

  .changelog-timeline {
    display: flex;
    flex-direction: column;
    gap: 1px;
    border-top: 1px solid var(--color-border);
  }

  .changelog-entry {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.25rem 0;
    border-bottom: 1px solid var(--color-border);
    transition: background 0.15s;
    text-decoration: none;
    color: inherit;
    margin: 0 -0.75rem;
    padding-left: 0.75rem;
    padding-right: 0.75rem;
    border-radius: var(--radius-sm);
  }

  .changelog-entry:hover {
    background: var(--color-bg-alt);
  }

  .changelog-entry-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .changelog-version {
    font-family: var(--font-mono);
    font-size: 1rem;
    font-weight: 500;
    color: var(--color-text);
  }

  .changelog-breaking-badge {
    display: inline-block;
    font-family: var(--font-sans);
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: #b45309;
    background: #fef3c7;
    border: 1px solid #fde68a;
    padding: 0.2em 0.6em;
    border-radius: var(--radius-pill);
  }

  .changelog-date {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    white-space: nowrap;
  }

  @media (max-width: 480px) {
    .changelog-entry {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.35rem;
    }
  }
</style>
