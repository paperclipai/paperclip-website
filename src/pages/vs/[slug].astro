---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const comparisons = await getCollection('comparisons');
  return comparisons.map((comp) => ({
    params: { slug: comp.id },
    props: { comp },
  }));
}

const { comp } = Astro.props;
const { Content } = await render(comp);
---

<Layout
  title={comp.data.title}
  description={comp.data.excerpt}
>
  <div class="vs-page">
    <Navbar />

    <article class="vs-article">
      <header class="vs-header">
        <div class="vs-header-bg"></div>
        <div class="container vs-header-content">
          <a href="/vs" class="vs-back-link">&larr; All comparisons</a>
          <span class="vs-badge">Comparison</span>
          <h1 class="heading-serif vs-title">Paperclip vs {comp.data.competitor}</h1>
          <p class="vs-excerpt">{comp.data.excerpt}</p>
        </div>
      </header>

      <div class="container">
        <div class="vs-content">
          <Content />
        </div>
      </div>

      <section class="vs-cta-section">
        <div class="container vs-cta-inner">
          <h2 class="heading-serif vs-cta-heading">Try Paperclip Today</h2>
          <p class="vs-cta-sub">
            Open source. Self-hosted. From zero to autonomous company in one command.
          </p>
          <div class="vs-cta-links">
            <a href="https://github.com/paperclipai/paperclip" class="vs-cta-btn">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
              Star on GitHub
            </a>
            <a href="https://docs.paperclip.ing" class="vs-cta-link">Read the docs &rarr;</a>
          </div>
        </div>
      </section>
    </article>

    <Footer />
  </div>
</Layout>

<style>
  .vs-page {
    background: var(--color-bg);
  }

  /* ── Header ── */
  .vs-header {
    position: relative;
    overflow: hidden;
  }

  .vs-header-bg {
    position: relative;
    width: 100%;
    height: 32vh;
    min-height: 200px;
    max-height: 340px;
    background: linear-gradient(
      135deg,
      #1a1a1a 0%,
      #2d2a26 40%,
      #3d3830 70%,
      #1a1a1a 100%
    );
  }

  .vs-header-bg::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      transparent 0%,
      rgba(0, 0, 0, 0.3) 100%
    );
  }

  .vs-header-content {
    position: relative;
    z-index: 1;
    margin-top: -7rem;
    padding-bottom: var(--space-lg);
  }

  .vs-back-link {
    display: inline-block;
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.5);
    margin-bottom: var(--space-md);
    transition: color 0.2s;
  }

  .vs-back-link:hover {
    color: #fff;
  }

  .vs-badge {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: rgba(255, 255, 255, 0.7);
    background: rgba(255, 255, 255, 0.1);
    padding: 0.25em 0.75em;
    border-radius: var(--radius-pill);
    margin-bottom: var(--space-sm);
  }

  .vs-title {
    font-size: clamp(2rem, 4.5vw, 3rem);
    margin-bottom: 0.75rem;
    max-width: 720px;
    color: #fff;
  }

  .vs-excerpt {
    font-size: 1.1rem;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.6);
    max-width: 620px;
  }

  /* ── Prose content ── */
  .vs-content {
    max-width: 680px;
    padding-top: var(--space-lg);
    padding-bottom: var(--space-xl);
  }

  .vs-content :global(h2) {
    font-family: var(--font-serif);
    font-size: 1.6rem;
    font-weight: 400;
    margin-top: var(--space-xl);
    margin-bottom: var(--space-sm);
    color: var(--color-text);
  }

  .vs-content :global(h3) {
    font-family: var(--font-sans);
    font-size: 1.15rem;
    font-weight: 600;
    margin-top: var(--space-lg);
    margin-bottom: 0.5rem;
    color: var(--color-text);
  }

  .vs-content :global(p) {
    font-size: 1.05rem;
    line-height: 1.7;
    color: var(--color-text-secondary);
    margin-bottom: var(--space-sm);
  }

  .vs-content :global(ul),
  .vs-content :global(ol) {
    padding-left: 1.5rem;
    margin-bottom: var(--space-sm);
  }

  .vs-content :global(ul) {
    list-style: disc;
  }

  .vs-content :global(ol) {
    list-style: decimal;
  }

  .vs-content :global(li) {
    font-size: 1.05rem;
    line-height: 1.7;
    color: var(--color-text-secondary);
    margin-bottom: 0.35rem;
  }

  .vs-content :global(strong) {
    font-weight: 600;
    color: var(--color-text);
  }

  .vs-content :global(a) {
    color: var(--color-text);
    text-decoration: underline;
    text-underline-offset: 2px;
    transition: color 0.2s;
  }

  .vs-content :global(a:hover) {
    color: var(--color-text-secondary);
  }

  .vs-content :global(code) {
    font-family: var(--font-mono);
    font-size: 0.9em;
    background: var(--color-surface);
    padding: 0.15em 0.4em;
    border-radius: 4px;
  }

  .vs-content :global(blockquote) {
    border-left: 3px solid var(--color-border);
    padding-left: var(--space-md);
    margin-bottom: var(--space-sm);
    color: var(--color-text-muted);
    font-style: italic;
  }

  .vs-content :global(hr) {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: var(--space-xl) 0;
  }

  /* ── Tables ── */
  .vs-content :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: var(--space-lg);
    font-size: 0.95rem;
  }

  .vs-content :global(thead) {
    border-bottom: 2px solid var(--color-border);
  }

  .vs-content :global(th) {
    text-align: left;
    font-weight: 600;
    color: var(--color-text);
    padding: 0.75rem 1rem;
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }

  .vs-content :global(td) {
    padding: 0.65rem 1rem;
    color: var(--color-text-secondary);
    border-bottom: 1px solid var(--color-border);
  }

  .vs-content :global(tbody tr:last-child td) {
    border-bottom: none;
  }

  .vs-content :global(tbody tr:hover) {
    background: var(--color-surface);
  }

  @media (max-width: 768px) {
    .vs-content :global(table) {
      display: block;
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
    }

    .vs-content :global(th),
    .vs-content :global(td) {
      padding: 0.5rem 0.75rem;
      white-space: nowrap;
    }
  }

  /* ── CTA Section ── */
  .vs-cta-section {
    background: var(--color-bg-alt);
    border-top: 1px solid var(--color-border);
    padding: var(--space-3xl) 0;
    text-align: center;
  }

  .vs-cta-inner {
    max-width: 560px;
  }

  .vs-cta-heading {
    font-size: clamp(1.8rem, 3.5vw, 2.4rem);
    margin-bottom: var(--space-md);
  }

  .vs-cta-sub {
    color: var(--color-text-muted);
    font-size: 1rem;
    line-height: 1.7;
    max-width: 440px;
    margin: 0 auto var(--space-lg);
  }

  .vs-cta-links {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-md);
    flex-wrap: wrap;
  }

  .vs-cta-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--color-bg);
    background: var(--color-text);
    padding: 0.6rem 1.3rem;
    border-radius: var(--radius-pill);
    transition: opacity 0.2s;
  }

  .vs-cta-btn:hover {
    opacity: 0.85;
  }

  .vs-cta-link {
    font-size: 0.95rem;
    color: var(--color-text-secondary);
    transition: color 0.2s;
  }

  .vs-cta-link:hover {
    color: var(--color-text);
  }
</style>
