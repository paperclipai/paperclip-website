---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';

const comparisons = await getCollection('comparisons');
const sorted = comparisons.sort((a, b) => a.data.order - b.data.order);
---

<Layout
  title="Paperclip vs Alternatives — AI Agent Coordination Compared"
  description="See how Paperclip compares to other AI agent platforms. Honest, side-by-side comparisons with feature tables."
>
  <div class="vs-index-page">
    <Navbar />

    <header class="vs-index-header">
      <div class="vs-index-header-image">
        <picture>
          <source srcset="/blog-header.webp" type="image/webp" />
          <img src="/blog-header.jpg" alt="" width="1920" height="960" loading="eager" />
        </picture>
      </div>
      <div class="container vs-index-header-content">
        <span class="vs-index-badge">Comparisons</span>
        <h1 class="heading-serif vs-index-title">How Paperclip Compares</h1>
        <p class="vs-index-subtitle">
          Honest, side-by-side comparisons with the tools you're evaluating.
          We highlight what each does well and where Paperclip differs.
        </p>
      </div>
    </header>

    <section class="container vs-index-grid-section">
      <div class="vs-index-grid">
        {sorted.map((comp) => (
          <a href={`/vs/${comp.id}`} class="vs-card">
            {comp.data.coverImage ? (
              <div class="vs-card-thumb">
                <img src={comp.data.coverImage} alt={`Paperclip vs ${comp.data.competitor}`} class="vs-card-thumb-img" />
              </div>
            ) : (
              <div class="vs-card-thumb vs-card-thumb--gradient"></div>
            )}
            <div class="vs-card-body">
              <span class="vs-card-badge">vs</span>
              <h2 class="vs-card-title">Paperclip vs {comp.data.competitor}</h2>
              <p class="vs-card-excerpt">{comp.data.excerpt}</p>
              <span class="vs-card-link">Read comparison &rarr;</span>
            </div>
          </a>
        ))}
      </div>
    </section>

    <Footer />
  </div>
</Layout>

<style>
  .vs-index-page {
    background: var(--color-bg);
  }

  /* ── Header ── */
  .vs-index-header {
    position: relative;
    overflow: hidden;
  }

  .vs-index-header-image {
    position: relative;
    width: 100%;
    height: 40vh;
    min-height: 240px;
    max-height: 420px;
    overflow: hidden;
  }

  .vs-index-header-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center bottom;
    display: block;
  }

  .vs-index-header-image::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(0, 0, 0, 0.15) 0%,
      rgba(0, 0, 0, 0.4) 50%,
      rgba(0, 0, 0, 0.6) 100%
    );
  }

  .vs-index-header-content {
    position: relative;
    z-index: 1;
    margin-top: -7rem;
    margin-bottom: clamp(1rem, 3vw, 1.75rem);
    padding: clamp(1.1rem, 3vw, 1.8rem);
    padding-bottom: clamp(1.4rem, 3.5vw, 2rem);
    border-radius: 28px;
    background: linear-gradient(180deg, rgba(10, 14, 26, 0.96) 0%, rgba(10, 14, 26, 0.99) 100%);
    border: 1px solid rgba(255, 255, 255, 0.06);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.04);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    text-align: center;
  }

  .vs-index-badge {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: rgba(255, 255, 255, 0.7);
    background: rgba(255, 255, 255, 0.1);
    padding: 0.2em 0.65em;
    border-radius: var(--radius-pill);
    margin-bottom: var(--space-sm);
  }

  .vs-index-title {
    font-size: clamp(2.2rem, 5vw, 3.2rem);
    margin-bottom: 0.75rem;
    color: #fff;
  }

  .vs-index-subtitle {
    font-size: 1.1rem;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.82);
    max-width: 520px;
    margin: 0 auto;
  }

  /* ── Grid ── */
  .vs-index-grid-section {
    padding-top: var(--space-xl);
    padding-bottom: var(--space-3xl);
  }

  .vs-index-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-md);
    max-width: 760px;
    margin: 0 auto;
  }

  .vs-card {
    display: flex;
    flex-direction: column;
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    overflow: hidden;
    transition: border-color 0.2s, box-shadow 0.2s;
  }

  .vs-card:hover {
    border-color: var(--color-text-muted);
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.06);
  }

  .vs-card-thumb {
    width: 100%;
    height: 140px;
    overflow: hidden;
  }

  .vs-card-thumb--gradient {
    background: linear-gradient(
      135deg,
      #1a1a1a 0%,
      #2d2a26 40%,
      #3d3830 70%,
      #1a1a1a 100%
    );
  }

  .vs-card-thumb-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .vs-card-body {
    padding: var(--space-lg);
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .vs-card-badge {
    display: inline-block;
    width: fit-content;
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-text-muted);
    background: var(--color-surface);
    padding: 0.2em 0.6em;
    border-radius: var(--radius-pill);
    margin-bottom: var(--space-sm);
  }

  .vs-card-title {
    font-family: var(--font-serif);
    font-size: 1.35rem;
    font-weight: 400;
    color: var(--color-text);
    margin-bottom: 0.5rem;
  }

  .vs-card-excerpt {
    font-size: 0.9rem;
    line-height: 1.6;
    color: var(--color-text-muted);
    margin-bottom: var(--space-sm);
    flex: 1;
  }

  .vs-card-link {
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--color-text-secondary);
    transition: color 0.2s;
  }

  .vs-card:hover .vs-card-link {
    color: var(--color-text);
  }

  @media (max-width: 768px) {
    .vs-index-header-content {
      margin-top: -5.5rem;
      margin-bottom: 1.25rem;
      border-radius: 22px;
    }
  }

  @media (max-width: 640px) {
    .vs-index-header-content {
      margin-top: -4.5rem;
      margin-bottom: 1rem;
      padding: 1rem;
      padding-bottom: 1.2rem;
      border-radius: 18px;
    }
  }

  @media (max-width: 600px) {
    .vs-index-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
