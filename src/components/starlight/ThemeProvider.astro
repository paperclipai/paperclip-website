---
/**
 * Docs are light-mode only. Replace Starlight's default ThemeProvider so
 * `prefers-color-scheme: dark` (or a stale localStorage value) can never
 * flip the docs to dark. Script is inlined to avoid FOUC.
 */
---

<script is:inline>
  window.StarlightThemeProvider = (() => {
    document.documentElement.dataset.theme = 'light';
    try {
      if (typeof localStorage !== 'undefined') {
        localStorage.setItem('starlight-theme', 'light');
      }
    } catch (_) {
      // ignore
    }
    return { updatePickers() {} };
  })();
</script>
