---
---

<footer class="footer">
  <div class="footer-bg">
    <picture>
      <source srcset="/footer-bg.webp" type="image/webp" />
      <img src="/footer-bg.jpg" alt="" width="1920" height="960" loading="lazy" />
    </picture>
  </div>

  <div class="footer-content">
    <div class="container footer-columns">
      <div class="footer-col">
        <h4 class="footer-col-heading">Product</h4>
        <a href="#get-started">Get started</a>
        <a href="#get-started">Quickstart</a>
        <!-- <a href="#">Pricing</a> -->
      </div>
      <div class="footer-col">
        <h4 class="footer-col-heading">Platform</h4>
        <a href="#get-started">Agents</a>
        <a href="#get-started">Governance</a>
        <a href="#get-started">Integrations</a>
      </div>
      <div class="footer-col">
        <h4 class="footer-col-heading">Developers</h4>
        <a href="https://github.com/paperclipai/paperclip">Documentation</a>
        <a href="https://github.com/paperclipai/paperclip">API reference</a>
        <a href="https://github.com/paperclipai/paperclip">GitHub</a>
      </div>
      <div class="footer-col">
        <h4 class="footer-col-heading">Resources</h4>
        <a href="/changelog">Changelog</a>
        <a href="https://github.com/paperclipai/paperclip">Contributing</a>
        <a href="https://github.com/paperclipai/paperclip">License</a>
        <a href="https://discord.gg/m4HZY7xNG3">Discord</a>
      </div>
    </div>

    <div class="container footer-bottom">
      <span class="footer-copy">&copy; {new Date().getFullYear()} Paperclip. Open source under MIT.</span>
      <!-- <div class="footer-bottom-links">
        <a href="#">Privacy</a>
        <a href="#">Terms</a>
      </div> -->
    </div>
  </div>
</footer>

<style>
  .footer {
    position: relative;
    overflow: hidden;
  }

  /* Background image — covers full footer area */
  .footer-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .footer-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    display: block;
  }

  /* Semi-transparent overlay so text reads clearly */
  .footer-bg::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(20, 30, 50, 0.65) 0%,
      rgba(20, 30, 50, 0.55) 60%,
      rgba(20, 30, 50, 0.7) 100%
    );
  }

  .footer-content {
    position: relative;
    z-index: 1;
  }

  /* ── Link columns ── */
  .footer-columns {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-lg);
    padding-top: clamp(3rem, 6vw, 5rem);
    padding-bottom: clamp(4rem, 10vw, 8rem);
  }

  .footer-col-heading {
    font-family: var(--font-sans);
    font-size: 0.85rem;
    font-weight: 600;
    color: #ffffff;
    margin-bottom: 0.85rem;
    letter-spacing: 0.01em;
  }

  .footer-col a {
    display: block;
    font-size: 0.875rem;
    color: rgba(255, 255, 255, 0.65);
    padding: 0.25rem 0;
    transition: color 0.2s;
  }

  .footer-col a:hover {
    color: #ffffff;
  }

  /* ── Bottom bar ── */
  .footer-bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: var(--space-sm);
    padding-top: var(--space-md);
    padding-bottom: var(--space-md);
    border-top: 1px solid rgba(255, 255, 255, 0.15);
  }

  .footer-copy {
    font-size: 0.8rem;
    color: rgba(255, 255, 255, 0.45);
  }

  .footer-bottom-links {
    display: flex;
    gap: var(--space-md);
  }

  .footer-bottom-links a {
    font-size: 0.8rem;
    color: rgba(255, 255, 255, 0.45);
    transition: color 0.2s;
  }

  .footer-bottom-links a:hover {
    color: rgba(255, 255, 255, 0.8);
  }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .footer-columns {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-lg) var(--space-md);
    }
  }

  @media (max-width: 480px) {
    .footer-bottom {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
