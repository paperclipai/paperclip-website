---
---

<section class="feature-section section">
  <div class="container">
    <hr class="section-divider" />
    <div class="feature-header">
      <div>
        <span class="section-badge">Cost Tracking</span>
        <h2 class="heading-serif feature-heading">Know what every agent costs.<br />Control what every agent spends.</h2>
        <p class="feature-sub">
          Every agent gets a monthly budget. When they hit it, they stop. Automatically.
          No runaway costs. No surprise bills. Hard limits, enforced by the system.
        </p>
      </div>
    </div>
    <div class="feature-layout">
      <div class="graphic-placeholder">
        <!-- Budget / cost bars -->
        <svg viewBox="0 0 480 320" fill="none" xmlns="http://www.w3.org/2000/svg">
          <!-- Header labels -->
          <text x="40" y="40" font-family="Inter, sans-serif" font-size="11" font-weight="600" fill="#1a1a1a">Agent</text>
          <text x="160" y="40" font-family="Inter, sans-serif" font-size="11" font-weight="600" fill="#1a1a1a">Budget Used</text>
          <text x="400" y="40" font-family="Inter, sans-serif" font-size="11" font-weight="600" fill="#1a1a1a">Cost</text>
          <line x1="40" y1="50" x2="440" y2="50" stroke="#d4d0ca" stroke-width="1"/>

          <!-- Row 1 -->
          <text x="40" y="80" font-family="Inter, sans-serif" font-size="12" fill="#1a1a1a">CEO Agent</text>
          <rect x="160" y="66" width="200" height="20" rx="4" fill="#e8e4de"/>
          <rect x="160" y="66" width="140" height="20" rx="4" fill="#1a1a1a"/>
          <text x="400" y="80" font-family="Inter, sans-serif" font-size="12" fill="#4a4a4a">$42</text>
          <text x="440" y="80" font-family="Inter, sans-serif" font-size="10" fill="#888880">/60</text>

          <!-- Row 2 -->
          <text x="40" y="120" font-family="Inter, sans-serif" font-size="12" fill="#1a1a1a">CTO Agent</text>
          <rect x="160" y="106" width="200" height="20" rx="4" fill="#e8e4de"/>
          <rect x="160" y="106" width="100" height="20" rx="4" fill="#1a1a1a"/>
          <text x="400" y="120" font-family="Inter, sans-serif" font-size="12" fill="#4a4a4a">$25</text>
          <text x="440" y="120" font-family="Inter, sans-serif" font-size="10" fill="#888880">/50</text>

          <!-- Row 3 -->
          <text x="40" y="160" font-family="Inter, sans-serif" font-size="12" fill="#1a1a1a">Engineer 1</text>
          <rect x="160" y="146" width="200" height="20" rx="4" fill="#e8e4de"/>
          <rect x="160" y="146" width="60" height="20" rx="4" fill="#1a1a1a"/>
          <text x="400" y="160" font-family="Inter, sans-serif" font-size="12" fill="#4a4a4a">$9</text>
          <text x="440" y="160" font-family="Inter, sans-serif" font-size="10" fill="#888880">/30</text>

          <!-- Row 4 -->
          <text x="40" y="200" font-family="Inter, sans-serif" font-size="12" fill="#1a1a1a">Engineer 2</text>
          <rect x="160" y="186" width="200" height="20" rx="4" fill="#e8e4de"/>
          <rect x="160" y="186" width="170" height="20" rx="4" fill="#1a1a1a"/>
          <text x="400" y="200" font-family="Inter, sans-serif" font-size="12" fill="#4a4a4a">$26</text>
          <text x="440" y="200" font-family="Inter, sans-serif" font-size="10" fill="#888880">/30</text>

          <!-- Row 5 -->
          <text x="40" y="240" font-family="Inter, sans-serif" font-size="12" fill="#1a1a1a">Content</text>
          <rect x="160" y="226" width="200" height="20" rx="4" fill="#e8e4de"/>
          <rect x="160" y="226" width="30" height="20" rx="4" fill="#1a1a1a"/>
          <text x="400" y="240" font-family="Inter, sans-serif" font-size="12" fill="#4a4a4a">$6</text>
          <text x="440" y="240" font-family="Inter, sans-serif" font-size="10" fill="#888880">/40</text>

          <!-- Total -->
          <line x1="40" y1="260" x2="440" y2="260" stroke="#d4d0ca" stroke-width="1"/>
          <text x="40" y="285" font-family="Inter, sans-serif" font-size="12" font-weight="600" fill="#1a1a1a">Total</text>
          <text x="400" y="285" font-family="Inter, sans-serif" font-size="12" font-weight="600" fill="#1a1a1a">$108</text>
          <text x="440" y="285" font-family="Inter, sans-serif" font-size="10" fill="#888880">/210</text>
        </svg>
      </div>
      <div class="feature-details">
        <p class="feature-detail-text">
          Track costs per agent, per task, per project, per goal. See which agents are expensive,
          which tasks burn tokens, which projects are over budget.
        </p>
        <p class="feature-detail-emphasis">
          Real cost attribution — not estimates.
        </p>
      </div>
    </div>
  </div>
</section>

<style>
  .feature-header {
    padding-top: var(--space-2xl);
    margin-bottom: var(--space-xl);
  }

  .feature-heading {
    font-size: clamp(2rem, 4vw, 2.8rem);
    margin-bottom: var(--space-sm);
  }

  .feature-sub {
    color: var(--color-text-muted);
    font-size: 1rem;
    line-height: 1.7;
    max-width: 560px;
  }

  .feature-layout {
    display: grid;
    grid-template-columns: 1.3fr 0.7fr;
    gap: var(--space-lg);
    align-items: start;
  }

  .graphic-placeholder {
    background: var(--color-surface);
    border-radius: var(--radius-lg);
    min-height: 320px;
    padding: var(--space-sm);
  }

  .feature-details {
    padding-top: var(--space-md);
  }

  .feature-detail-text {
    color: var(--color-text-muted);
    font-size: 1rem;
    line-height: 1.7;
    margin-bottom: var(--space-sm);
  }

  .feature-detail-emphasis {
    font-weight: 600;
    font-size: 1rem;
    color: var(--color-text);
  }

  @media (max-width: 768px) {
    .feature-layout {
      grid-template-columns: 1fr;
    }
  }
</style>
