</section>

<style>
  .feature-header {
    padding-top: var(--space-2xl);
    margin-bottom: var(--space-xl);
  }

  .feature-heading {
    font-size: clamp(2rem, 4vw, 2.8rem);
    margin-bottom: var(--space-sm);
  }

  .feature-sub {
    color: var(--color-text-muted);
    font-size: 1rem;
    line-height: 1.7;
    max-width: 560px;
  }

  .feature-layout {
    display: grid;
    grid-template-columns: 1.3fr 0.7fr;
    gap: var(--space-lg);
    align-items: start;
  }

  .cost-table-wrap {
    background: var(--color-surface);
    border-radius: var(--radius-lg);
    padding: var(--space-lg);
  }

  .cost-table {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .cost-header-row {
    display: grid;
    grid-template-columns: 160px 1fr 100px;
    gap: var(--space-sm);
    align-items: center;
    padding-bottom: 0.75rem;
  }

  .cost-header-row span {
    font-size: 0.72rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-muted);
  }

  .cost-divider {
    height: 1px;
    background: var(--color-border);
  }

  .cost-row {
    display: grid;
    grid-template-columns: 160px 1fr 100px;
    gap: var(--space-sm);
    align-items: center;
    padding: 0.65rem 0;
  }

  .cost-col-agent {
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }

  .cost-agent-icon {
    flex-shrink: 0;
    width: 28px;
    height: 28px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-bg);
    border-radius: 6px;
    color: var(--color-text-muted);
  }

  .cost-agent-icon svg {
    width: 16px;
    height: 16px;
  }

  .cost-agent-info {
    display: flex;
    flex-direction: column;
    gap: 1px;
    min-width: 0;
  }

  .cost-agent-name {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-text);
    white-space: nowrap;
  }

  .cost-agent-model {
    font-size: 0.68rem;
    color: var(--color-text-muted);
  }

  .cost-col-bar {
    min-width: 0;
  }

  .cost-bar-bg {
    width: 100%;
    height: 18px;
    background: var(--color-surface-raised);
    border-radius: 4px;
    overflow: hidden;
  }

  .cost-bar-fill {
    height: 100%;
    width: 0%;
    background: var(--color-text);
    border-radius: 4px;
    transition: width 1.2s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .cost-bar-fill.animate {
    width: var(--target-pct);
  }

  .cost-col-cost {
    display: flex;
    align-items: baseline;
    gap: 0.3rem;
    font-variant-numeric: tabular-nums;
  }

  .cost-amount {
    font-size: 0.9rem;
    color: var(--color-text-secondary);
  }

  .cost-amount--bold {
    font-weight: 600;
    color: var(--color-text);
  }

  .cost-budget {
    font-size: 0.75rem;
    color: var(--color-text-muted);
  }

  .cost-row--total {
    padding-top: 0.75rem;
  }

  .feature-details {
    padding-top: var(--space-md);
  }

  .feature-detail-text {
    color: var(--color-text-muted);
    font-size: 1rem;
    line-height: 1.7;
    margin-bottom: var(--space-sm);
  }

  @media (max-width: 768px) {
    .feature-layout {
      grid-template-columns: 1fr;
    }

    .cost-header-row,
    .cost-row {
      grid-template-columns: 130px 1fr 90px;
    }
  }

  @media (max-width: 480px) {
    .cost-header-row,
    .cost-row {
      grid-template-columns: 110px 1fr 80px;
    }

    .cost-agent-icon {
      display: none;
    }
  }
</style>

<script>
  const table = document.getElementById('cost-table');
  if (table) {
    const rows = table.querySelectorAll('.cost-row');
    const fills = table.querySelectorAll('.cost-bar-fill');

    function countUp(el, target, duration) {
      const start = performance.now();
      function tick(now) {
        const progress = Math.min((now - start) / duration, 1);
        const eased = 1 - Math.pow(1 - progress, 3);
        el.textContent = Math.round(eased * target);
        if (progress < 1) requestAnimationFrame(tick);
      }
      requestAnimationFrame(tick);
    }

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            // Animate bars
            fills.forEach((fill) => {
              fill.classList.add('animate');
            });

            // Count up cost numbers with stagger
            rows.forEach((row, i) => {
              const cost = parseInt(row.dataset.cost, 10);
              const numEl = row.querySelector('.cost-num');
              if (numEl && cost) {
                setTimeout(() => countUp(numEl, cost, 1000), i * 80);
              }
            });
          } else {
            // Reset when scrolled away
            fills.forEach((fill) => {
              fill.classList.remove('animate');
            });
            rows.forEach((row) => {
              const numEl = row.querySelector('.cost-num');
              if (numEl) numEl.textContent = '0';
            });
          }
        });
      },
      { threshold: 0.3 }
    );

    observer.observe(table);
  }
</script>
