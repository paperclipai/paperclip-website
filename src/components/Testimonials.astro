---
const tweets = [
  {
    name: "Numman Ali",
    username: "nummanali",
    avatar: "/testimonials/nummanali.jpg",
    text: "I've never seen an agent orchestration system that operates across all business functions\n\nAnd, neither have I seen one that has been built with great taste i.e. design and UX quality like Linear etc\n\nPaperclip seems to be special - no agent tie in either",
  },
  {
    name: "John Holloway",
    username: "JohnHolloway",
    avatar: "/testimonials/JohnHolloway.jpg",
    text: "Great for orchestrating a bunch of agents to do dev, content, social, marketing, qa, research, outreach, and anything else for an autonomous biz.",
  },
  {
    name: "Diogo D",
    username: "DiogoTheReal",
    avatar: "/testimonials/DiogoTheReal.jpg",
    text: "Been using it and works great!",
  },
  {
    name: "Logan",
    username: "logansaether",
    avatar: "/testimonials/logansaether.jpg",
    text: "When I first started playing with openclaw this was the vision I had for where you could take Agents.\n\nStarted to build my own, but it's nowhere near as polished as this.\n\nEveryone should go try Paperclip right now.",
  },
  {
    name: "neo",
    username: "dnalor_x",
    avatar: "/testimonials/dnalor_x.jpg",
    text: "Ok this blows everything out of the water! This is gonna be the interface of the future!",
  },
  {
    name: "Resolver Vicky",
    username: "resolvervicky",
    avatar: "/testimonials/resolvervicky.jpg",
    text: "OpenClaw is an employee, Paperclip is the company.",
  },
  {
    name: "JoelGG",
    username: "JoelGG",
    avatar: "/testimonials/JoelGG.jpg",
    text: "This is awesome! This replaces my mission control",
  },
  {
    name: "Wi_F_I",
    username: "Wi_F_I",
    avatar: "/testimonials/Wi_F_I.jpg",
    text: "been checking out Paperclip and it's pretty simple: it's a tool to organize and run work with AI agents instead of a bunch of separate automations\nit gives you org chart, goals, tasks, budgets and agent templates all in one place so you're not wiring everything from scratch",
  },
  {
    name: "alexander",
    username: "4tt4r",
    avatar: "/testimonials/4tt4r.jpg",
    text: "Just what I was looking for",
  },
  {
    name: "yash",
    username: "yashns1",
    avatar: "/testimonials/yashns1.jpg",
    text: 'The framing here is what makes this interesting. Not "here is an AI tool." CEO hires a Coder. You approve it. The mental model is a company you are running, not a tool you are using.\n\nThe shift from "I am prompting an AI" to "I am managing a team" changes how you think about what',
  },
  {
    name: "Evan Drake",
    username: "iamevandrake",
    avatar: "/testimonials/iamevandrake.jpg",
    text: "The rise of autonomous companies is inevitable. I tested Paperclip today and it blew my mind. I suggest giving it a spin.",
  },
];

const topRow = [...tweets, ...tweets];
const bottomRow = [...[...tweets].reverse(), ...[...tweets].reverse()];
---

<section class="testimonials-section">
  <div class="container testimonials-intro">
    <span class="section-badge">What people are saying</span>
    <h2 class="heading-serif testimonials-heading">Loved by builders.</h2>
  </div>

  <ul class="sr-only" aria-label="Testimonials from Paperclip users">
    {tweets.map((tweet) => (
      <li>{tweet.name} (@{tweet.username}): {tweet.text}</li>
    ))}
  </ul>

  <div class="testimonials-marquee" aria-hidden="true">
    <div class="carousel-fade carousel-fade-left"></div>
    <div class="carousel-fade carousel-fade-right"></div>

    <div class="carousel-track track-left">
      {topRow.map((tweet) => (
        <article class="tweet-card">
          <div class="tweet-topline">
            <div class="tweet-header">
              <img src={tweet.avatar} alt={tweet.name} class="tweet-avatar" loading="lazy" />
              <div class="tweet-author">
                <span class="tweet-name">{tweet.name}</span>
                <span class="tweet-handle">@{tweet.username}</span>
              </div>
            </div>
            <svg class="tweet-x-icon" width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" />
            </svg>
          </div>
          <p class="tweet-text">{tweet.text}</p>
        </article>
      ))}
    </div>

    <div class="carousel-track track-right">
      {bottomRow.map((tweet) => (
        <article class="tweet-card">
          <div class="tweet-topline">
            <div class="tweet-header">
              <img src={tweet.avatar} alt={tweet.name} class="tweet-avatar" loading="lazy" />
              <div class="tweet-author">
                <span class="tweet-name">{tweet.name}</span>
                <span class="tweet-handle">@{tweet.username}</span>
              </div>
            </div>
            <svg class="tweet-x-icon" width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" />
            </svg>
          </div>
          <p class="tweet-text">{tweet.text}</p>
        </article>
      ))}
    </div>
  </div>

  <div class="testimonials-mobile" aria-label="Testimonials from Paperclip users">
    {tweets.map((tweet) => (
      <article class="tweet-card">
        <div class="tweet-topline">
          <div class="tweet-header">
            <img src={tweet.avatar} alt={tweet.name} class="tweet-avatar" loading="lazy" />
            <div class="tweet-author">
              <span class="tweet-name">{tweet.name}</span>
              <span class="tweet-handle">@{tweet.username}</span>
            </div>
          </div>
          <svg class="tweet-x-icon" width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
            <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" />
          </svg>
        </div>
        <p class="tweet-text">{tweet.text}</p>
      </article>
    ))}
  </div>
</section>

<style>
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .testimonials-section {
    padding: var(--space-section) 0 var(--space-xl);
    overflow: hidden;
  }

  .testimonials-intro {
    margin-bottom: var(--space-lg);
  }

  .testimonials-heading {
    font-size: clamp(2rem, 4vw, 2.8rem);
  }

  .testimonials-marquee {
    position: relative;
    overflow: hidden;
    padding-inline: max(var(--space-md), calc((100vw - var(--max-width)) / 2));
    padding-block: 0.4rem;
  }

  .carousel-fade {
    position: absolute;
    top: 0;
    bottom: 0;
    width: clamp(4rem, 9vw, 9rem);
    z-index: 2;
    pointer-events: none;
  }

  .carousel-fade-left {
    left: 0;
    background: linear-gradient(90deg, var(--color-bg) 22%, rgba(255, 255, 255, 0));
  }

  .carousel-fade-right {
    right: 0;
    background: linear-gradient(270deg, var(--color-bg) 22%, rgba(255, 255, 255, 0));
  }

  .carousel-track {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    width: max-content;
  }

  .track-left {
    animation: scroll-left 58s linear infinite;
  }

  .track-right {
    margin-top: 1rem;
    animation: scroll-right 62s linear infinite;
  }

  @keyframes scroll-left {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  @keyframes scroll-right {
    0% { transform: translateX(-50%); }
    100% { transform: translateX(0); }
  }

  .tweet-card {
    position: relative;
    flex-shrink: 0;
    width: clamp(17rem, 24vw, 21rem);
    min-height: 14.5rem;
    padding: 1.1rem 1.1rem 1.2rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    border: 1px solid rgba(26, 26, 26, 0.09);
    border-radius: 22px;
    background:
      radial-gradient(circle at top right, rgba(231, 153, 195, 0.14), transparent 34%),
      linear-gradient(180deg, rgba(255, 255, 255, 0.98) 0%, var(--color-bg-alt) 100%);
    box-shadow: 0 20px 44px rgba(26, 26, 26, 0.07);
  }

  .tweet-card::before {
    content: "";
    position: absolute;
    inset: 0 0 auto;
    height: 4px;
    border-radius: 22px 22px 0 0;
    background: linear-gradient(90deg, #2ea5d7 0%, #f29eca 52%, #f2d072 100%);
  }

  .tweet-card::after {
    content: "“";
    position: absolute;
    right: 1rem;
    bottom: 0.45rem;
    font-family: var(--font-serif);
    font-size: 4.4rem;
    line-height: 1;
    color: rgba(26, 26, 26, 0.07);
    pointer-events: none;
  }

  .tweet-topline {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 0.75rem;
  }

  .tweet-header {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    min-width: 0;
    flex: 1;
  }

  .tweet-avatar {
    width: 2.75rem;
    height: 2.75rem;
    border-radius: 50%;
    object-fit: cover;
    border: 2px solid rgba(255, 255, 255, 0.95);
    box-shadow: 0 10px 24px rgba(26, 26, 26, 0.08);
  }

  .tweet-author {
    display: flex;
    flex-direction: column;
    min-width: 0;
  }

  .tweet-name {
    font-size: 0.98rem;
    font-weight: 600;
    line-height: 1.25;
    color: var(--color-text);
  }

  .tweet-handle {
    font-size: 0.82rem;
    line-height: 1.3;
    color: var(--color-text-muted);
  }

  .tweet-x-icon {
    flex-shrink: 0;
    color: rgba(26, 26, 26, 0.32);
  }

  .tweet-text {
    position: relative;
    z-index: 1;
    font-size: 1rem;
    line-height: 1.62;
    color: var(--color-text-secondary);
    display: -webkit-box;
    overflow: hidden;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 6;
  }

  .carousel-track:hover {
    animation-play-state: paused;
  }

  .testimonials-mobile {
    display: none;
  }

  @media (max-width: 900px) {
    .testimonials-section {
      padding-bottom: var(--space-lg);
    }

    .testimonials-intro {
      margin-bottom: var(--space-md);
    }

    .testimonials-marquee {
      display: none;
    }

    .testimonials-mobile {
      display: flex;
      gap: 1rem;
      overflow-x: auto;
      padding: 0 var(--space-md) 0.75rem;
      scroll-snap-type: x proximity;
      scrollbar-width: none;
      -webkit-overflow-scrolling: touch;
    }

    .testimonials-mobile::-webkit-scrollbar {
      display: none;
    }

    .testimonials-mobile .tweet-card {
      width: min(84vw, 21rem);
      min-height: 15rem;
      scroll-snap-align: start;
    }

    .testimonials-mobile .tweet-text {
      -webkit-line-clamp: 7;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .track-left,
    .track-right {
      animation: none;
    }
  }
</style>
