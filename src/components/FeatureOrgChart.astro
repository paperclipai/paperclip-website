      <!-- Right: org chart -->
      <div class="orgchart-visual">
        <div class="org-tree" id="org-tree">

          <!-- Level 0: CEO -->
          <div class="org-row org-row--single">
            <div class="org-card" data-role="ceo" style="--i:0">
              <div class="org-card__icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2 20h20"/><path d="M5 20V9l7-5 7 5v11"/><path d="M9 20v-5h6v5"/></svg>
              </div>
              <div class="org-card__body">
                <span class="org-card__name">CEO</span>
                <span class="org-card__model"><span class="org-card__dot"></span>Claude</span>
              </div>
            </div>
          </div>

          <div class="org-stem" style="--i:0.5"></div>

          <!-- Level 1: CMO, CTO, COO -->
          <div class="org-row org-row--three">
            <div class="org-card" data-role="cmo" style="--i:1">
              <div class="org-card__icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10 15.3 15.3 0 014-10z"/></svg>
              </div>
              <div class="org-card__body">
                <span class="org-card__name">CMO</span>
                <span class="org-card__model"><span class="org-card__dot"></span>OpenClaw</span>
              </div>
            </div>
            <div class="org-card" data-role="cto" style="--i:2">
              <div class="org-card__icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 01-2.83 2.83l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 01-4 0v-.09A1.65 1.65 0 009 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 01-2.83-2.83l.06-.06A1.65 1.65 0 004.68 15a1.65 1.65 0 00-1.51-1H3a2 2 0 010-4h.09A1.65 1.65 0 004.6 9a1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 012.83-2.83l.06.06A1.65 1.65 0 009 4.68a1.65 1.65 0 001-1.51V3a2 2 0 014 0v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 012.83 2.83l-.06.06A1.65 1.65 0 0019.4 9a1.65 1.65 0 001.51 1H21a2 2 0 010 4h-.09a1.65 1.65 0 00-1.51 1z"/></svg>
              </div>
              <div class="org-card__body">
                <span class="org-card__name">CTO</span>
                <span class="org-card__model"><span class="org-card__dot"></span>Cursor</span>
              </div>
            </div>
            <div class="org-card" data-role="coo" style="--i:3">
              <div class="org-card__icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M16 4h2a2 2 0 012 2v14a2 2 0 01-2 2H6a2 2 0 01-2-2V6a2 2 0 012-2h2"/><rect x="8" y="2" width="8" height="4" rx="1" ry="1"/></svg>
              </div>
              <div class="org-card__body">
                <span class="org-card__name">COO</span>
                <span class="org-card__model"><span class="org-card__dot"></span>Claude</span>
              </div>
            </div>
          </div>

          <div class="org-stem" style="--i:3.5"></div>

          <!-- Level 2: Engineers (under CTO) -->
          <div class="org-row org-row--two">
            <div class="org-card" data-role="eng1" style="--i:4">
              <div class="org-card__icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
              </div>
              <div class="org-card__body">
                <span class="org-card__name">CodexCoder</span>
                <span class="org-card__title">Engineer</span>
                <span class="org-card__model"><span class="org-card__dot"></span>Codex</span>
              </div>
            </div>
            <div class="org-card" data-role="eng2" style="--i:5">
              <div class="org-card__icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
              </div>
              <div class="org-card__body">
                <span class="org-card__name">ClaudeCoder</span>
                <span class="org-card__title">Engineer</span>
                <span class="org-card__model"><span class="org-card__dot"></span>Claude</span>
              </div>
            </div>
          </div>

        </div>
      </div>
    </div>
  </div>
</section>

<script>
  // Kill any previous loop and clean up stale DOM
  window.__pcStop = true;
  document.querySelectorAll('.task-packet').forEach(el => el.remove());
  document.querySelectorAll('.org-card.is-live').forEach(el => el.classList.remove('is-live'));

  const tree = document.getElementById('org-tree');
  if (tree && !tree.dataset.flowQueued) {
    tree.dataset.flowQueued = '1';

    const rect = tree.getBoundingClientRect();
    const inView = rect.top < window.innerHeight && rect.bottom > 0;

    if (inView) {
      tree.classList.add('is-visible');
      setTimeout(() => startTaskFlow(tree), 800);
    } else {
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              tree.classList.add('is-visible');
              observer.unobserve(tree);
              setTimeout(() => startTaskFlow(tree), 2200);
            }
          });
        },
        { threshold: 0.15 }
      );
      observer.observe(tree);
    }
  }

  function startTaskFlow(tree) {
    // Only one loop at a time
    if (tree.dataset.flowRunning) return;
    tree.dataset.flowRunning = '1';
    window.__pcStop = false;

    const get = (role) => tree.querySelector(`[data-role="${role}"]`);
    const cards = { ceo: get('ceo'), cmo: get('cmo'), cto: get('cto'), coo: get('coo'), eng1: get('eng1'), eng2: get('eng2') };
    if (!cards.ceo) { delete tree.dataset.flowRunning; return; }

    const PW = 16;
    const PH = 8;
    const HALF_W = PW / 2;
    const HALF_H = PH / 2;

    // Clean up any stale packets, create fresh one
    document.querySelectorAll('.task-packet').forEach(el => el.remove());
    const packet = document.createElement('div');
    packet.className = 'task-packet';
    packet.style.opacity = '0';
    tree.appendChild(packet);

    function pos(card) {
      const tr = tree.getBoundingClientRect();
      const cr = card.getBoundingClientRect();
      return {
        cx: cr.left + cr.width / 2 - tr.left,
        top: cr.top - tr.top,
        bottom: cr.bottom - tr.top,
      };
    }

    function delay(ms) { return new Promise(r => setTimeout(r, ms)); }
    function alive() { return !window.__pcStop; }

    function setPos(x, y) {
      packet.style.transition = 'none';
      packet.style.left = (x - HALF_W) + 'px';
      packet.style.top = (y - HALF_H) + 'px';
      packet.getBoundingClientRect();
    }

    function slideTo(x, y, ms, ease) {
      return new Promise(resolve => {
        packet.style.transition = `left ${ms}ms ${ease}, top ${ms}ms ${ease}`;
        packet.style.left = (x - HALF_W) + 'px';
        packet.style.top = (y - HALF_H) + 'px';
        setTimeout(resolve, ms + 30);
      });
    }

    async function send(fromCard, toCard) {
      if (!alive()) return;
      const from = pos(fromCard);
      const to = pos(toCard);
      const barY = to.top - 20;

      setPos(from.cx, from.bottom + 2);
      packet.style.opacity = '1';
      packet.getBoundingClientRect();

      await slideTo(from.cx, barY, 550, 'ease-in');
      if (!alive()) return;
      await slideTo(to.cx, barY, 650, 'linear');
      if (!alive()) return;
      await slideTo(to.cx, to.top - 2, 400, 'ease-in');
      if (!alive()) return;

      packet.style.transition = 'opacity 0.2s ease';
      packet.style.opacity = '0';
      toCard.classList.add('is-live');
      await delay(250);
    }

    function clearLive(...list) {
      list.forEach(c => c.classList.remove('is-live'));
    }

    async function loop() {
      while (alive()) {
        await send(cards.ceo, cards.cto);
        if (!alive()) break;
        await delay(300);
        await send(cards.cto, cards.eng1);
        if (!alive()) break;
        await send(cards.cto, cards.eng2);
        if (!alive()) break;
        await delay(1500);
        clearLive(cards.eng1, cards.eng2, cards.cto);
        await delay(1000);
        if (!alive()) break;

        await send(cards.ceo, cards.cmo);
        if (!alive()) break;
        await delay(1500);
        clearLive(cards.cmo);
        await delay(1000);
        if (!alive()) break;

        await send(cards.ceo, cards.coo);
        if (!alive()) break;
        await delay(1500);
        clearLive(cards.coo);
        await delay(1500);
      }
      delete tree.dataset.flowRunning;
    }

    console.log('[paperclip] task flow started (single instance)');
    loop();
  }
</script>

<style>
  .feature-section {
    padding-bottom: var(--space-lg);
  }

  /* ── Two-column layout ── */
  .orgchart-two-col {
    display: grid;
    grid-template-columns: 5fr 7fr;
    gap: var(--space-xl);
    align-items: stretch;
    padding-top: var(--space-lg);
  }

  .orgchart-copy {
    padding-top: var(--space-xs);
  }

  .feature-heading {
    font-size: clamp(2rem, 4vw, 2.8rem);
    margin-bottom: var(--space-sm);
  }

  .feature-sub {
    color: var(--color-text-muted);
    font-size: 1rem;
    line-height: 1.7;
    max-width: 420px;
  }

  /* ── Works with ── */
  .works-with {
    margin-top: var(--space-xl);
  }

  .works-with-label {
    display: block;
    font-style: italic;
    font-size: 0.95rem;
    color: var(--color-text-muted);
    margin-bottom: var(--space-sm);
  }

  .works-with-logos {
    display: flex;
    gap: var(--space-lg);
  }

  .logo-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.4rem;
    filter: grayscale(1) opacity(0.5);
    transition: filter 0.3s ease;
  }

  .logo-item:hover {
    filter: grayscale(0) opacity(1);
  }

  .logo-icon {
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .logo-icon svg {
    width: 100%;
    height: 100%;
  }

  .logo-icon--claude svg {
    width: 26px;
    height: 26px;
  }

  .logo-icon--openclaw svg {
    width: 30px;
    height: 30px;
  }

  .logo-name {
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--color-text-muted);
  }

  /* ── Org chart visual ── */
  .orgchart-visual {
    background: var(--color-surface);
    border-radius: var(--radius-lg);
    display: flex;
    align-items: stretch;
    justify-content: center;
    padding: var(--space-md);
    overflow: hidden;
  }

  /* ── Org tree structure ── */
  .org-tree {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    width: 100%;
    gap: 0;
  }

  /* Rows */
  .org-row {
    display: flex;
    justify-content: center;
    gap: 10px;
    width: 100%;
    position: relative;
  }

  .org-row--single {
    justify-content: center;
  }

  .org-row--single .org-card {
    min-width: 140px;
  }

  .org-row--three {
    padding-top: 20px;
  }

  .org-row--three .org-card {
    flex: 1;
    max-width: 180px;
  }

  .org-row--two {
    max-width: 62%;
    padding-top: 20px;
  }

  .org-row--two .org-card {
    flex: 1;
    max-width: 180px;
  }

  /* Horizontal bar for 3-child row */
  .org-row--three::before {
    content: '';
    position: absolute;
    top: 0;
    /* Account for 10px gaps between 3 flex children */
    left: calc((100% - 20px) / 6);
    right: calc((100% - 20px) / 6);
    height: 2px;
    background: #b5b0a8;
    z-index: 1;
  }

  /* Drop lines — from bar to card top, NOT into the card */
  .org-row--three .org-card::before {
    content: '';
    position: absolute;
    top: -20px;
    left: 50%;
    transform: translateX(-50%);
    width: 2px;
    height: 20px;
    background: #b5b0a8;
    z-index: 1;
  }

  /* Horizontal bar for 2-child row */
  .org-row--two::before {
    content: '';
    position: absolute;
    top: 0;
    /* Account for 10px gap between 2 flex children */
    left: calc((100% - 10px) / 4);
    right: calc((100% - 10px) / 4);
    height: 2px;
    background: #b5b0a8;
    z-index: 1;
  }

  /* Drop lines for 2-child row */
  .org-row--two .org-card::before {
    content: '';
    position: absolute;
    top: -20px;
    left: 50%;
    transform: translateX(-50%);
    width: 2px;
    height: 20px;
    background: #b5b0a8;
    z-index: 1;
  }

  /* Vertical stems — overlap 3px into the row below */
  .org-stem {
    width: 2px;
    height: 20px;
    background: #b5b0a8;
    margin-bottom: -3px;
    position: relative;
    z-index: 1;
  }

  /* ── Org card ── */
  .org-card {
    position: relative;
    z-index: 3;
    display: flex;
    align-items: flex-start;
    gap: 10px;
    padding: 12px 14px;
    background: var(--color-bg);
    border: 1.5px solid var(--color-border);
    border-radius: var(--radius-sm);
    transition: border-color 0.3s ease, box-shadow 0.3s ease;
  }

  /* Live state (global — toggled via JS) */
  .org-card:global(.is-live) {
    border-color: #22c55e;
    box-shadow: 0 0 0 1.5px rgba(34, 197, 94, 0.25);
  }

  .org-card:global(.is-live)::after {
    content: 'Active';
    position: absolute;
    top: -9px;
    right: 10px;
    font-size: 0.58rem;
    font-weight: 600;
    padding: 1px 7px;
    background: #dcfce7;
    color: #166534;
    border-radius: 100px;
    letter-spacing: 0.02em;
  }

  .org-card__icon {
    flex-shrink: 0;
    width: 28px;
    height: 28px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-surface);
    border-radius: 6px;
    color: var(--color-text-muted);
    margin-top: 1px;
  }

  .org-card__icon svg {
    width: 16px;
    height: 16px;
  }

  .org-card__body {
    display: flex;
    flex-direction: column;
    gap: 1px;
    min-width: 0;
  }

  .org-card__name {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--color-text);
    line-height: 1.3;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .org-card__title {
    font-size: 0.7rem;
    color: var(--color-text-secondary);
    line-height: 1.3;
  }

  .org-card__model {
    display: flex;
    align-items: center;
    gap: 5px;
    font-size: 0.68rem;
    color: var(--color-text-muted);
    line-height: 1.3;
  }

  .org-card__dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #e5a536;
    flex-shrink: 0;
  }

  /* ── Task packet (global — dynamically created via JS) ── */
  :global(.task-packet) {
    position: absolute;
    width: 16px;
    height: 8px;
    background: #22c55e;
    border-radius: 4px;
    opacity: 0;
    z-index: 4;
    pointer-events: none;
    box-shadow: 0 0 6px rgba(34, 197, 94, 0.6);
  }

  /* ── Reveal animation ── */
  .org-tree .org-card,
  .org-tree .org-stem {
    opacity: 0;
  }

  .org-tree .org-row--three::before,
