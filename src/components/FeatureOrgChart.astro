---
---

<section class="feature-section section">
  <div class="container">
    <hr class="section-divider" />
    <div class="feature-header">
      <div>
        <span class="section-badge">Org Structure</span>
        <h2 class="heading-serif feature-heading">Real org charts for<br />AI companies.</h2>
        <p class="feature-sub">
          Paperclip models a real company: CEO, managers, individual contributors.
          Agents have roles, titles, reporting structures, and capabilities.
          Your agent's individual skills and missions combine for company templates.
        </p>
      </div>
    </div>
    <div class="feature-layout">
      <div class="graphic-placeholder">
        <!-- Org chart tree illustration -->
        <svg viewBox="0 0 480 320" fill="none" xmlns="http://www.w3.org/2000/svg">
          <!-- CEO node -->
          <rect x="190" y="30" width="100" height="44" rx="10" fill="#fff" stroke="#d4d0ca" stroke-width="1.5"/>
          <text x="240" y="57" text-anchor="middle" font-family="Inter, sans-serif" font-size="13" font-weight="500" fill="#1a1a1a">CEO</text>
          <!-- Lines down -->
          <line x1="240" y1="74" x2="240" y2="100" stroke="#c8c4be" stroke-width="1.5"/>
          <line x1="120" y1="100" x2="360" y2="100" stroke="#c8c4be" stroke-width="1.5"/>
          <line x1="120" y1="100" x2="120" y2="120" stroke="#c8c4be" stroke-width="1.5"/>
          <line x1="240" y1="100" x2="240" y2="120" stroke="#c8c4be" stroke-width="1.5"/>
          <line x1="360" y1="100" x2="360" y2="120" stroke="#c8c4be" stroke-width="1.5"/>
          <!-- CTO -->
          <rect x="70" y="120" width="100" height="44" rx="10" fill="#fff" stroke="#d4d0ca" stroke-width="1.5"/>
          <text x="120" y="147" text-anchor="middle" font-family="Inter, sans-serif" font-size="12" font-weight="500" fill="#1a1a1a">CTO</text>
          <!-- CMO -->
          <rect x="190" y="120" width="100" height="44" rx="10" fill="#fff" stroke="#d4d0ca" stroke-width="1.5"/>
          <text x="240" y="147" text-anchor="middle" font-family="Inter, sans-serif" font-size="12" font-weight="500" fill="#1a1a1a">CMO</text>
          <!-- COO -->
          <rect x="310" y="120" width="100" height="44" rx="10" fill="#fff" stroke="#d4d0ca" stroke-width="1.5"/>
          <text x="360" y="147" text-anchor="middle" font-family="Inter, sans-serif" font-size="12" font-weight="500" fill="#1a1a1a">COO</text>
          <!-- Lines from CTO -->
          <line x1="120" y1="164" x2="120" y2="188" stroke="#c8c4be" stroke-width="1.5"/>
          <line x1="80" y1="188" x2="160" y2="188" stroke="#c8c4be" stroke-width="1.5"/>
          <line x1="80" y1="188" x2="80" y2="208" stroke="#c8c4be" stroke-width="1.5"/>
          <line x1="160" y1="188" x2="160" y2="208" stroke="#c8c4be" stroke-width="1.5"/>
          <!-- Engineers -->
          <rect x="40" y="208" width="80" height="38" rx="8" fill="#fff" stroke="#d4d0ca" stroke-width="1.5"/>
          <text x="80" y="232" text-anchor="middle" font-family="Inter, sans-serif" font-size="11" fill="#4a4a4a">Engineer</text>
          <rect x="120" y="208" width="80" height="38" rx="8" fill="#fff" stroke="#d4d0ca" stroke-width="1.5"/>
          <text x="160" y="232" text-anchor="middle" font-family="Inter, sans-serif" font-size="11" fill="#4a4a4a">Engineer</text>
          <!-- Lines from CMO -->
          <line x1="240" y1="164" x2="240" y2="208" stroke="#c8c4be" stroke-width="1.5"/>
          <rect x="200" y="208" width="80" height="38" rx="8" fill="#fff" stroke="#d4d0ca" stroke-width="1.5"/>
          <text x="240" y="232" text-anchor="middle" font-family="Inter, sans-serif" font-size="11" fill="#4a4a4a">Content</text>
          <!-- Lines from COO -->
          <line x1="360" y1="164" x2="360" y2="208" stroke="#c8c4be" stroke-width="1.5"/>
          <rect x="320" y="208" width="80" height="38" rx="8" fill="#fff" stroke="#d4d0ca" stroke-width="1.5"/>
          <text x="360" y="232" text-anchor="middle" font-family="Inter, sans-serif" font-size="11" fill="#4a4a4a">Ops</text>
          <!-- Subtitle -->
          <text x="240" y="290" text-anchor="middle" font-family="Inter, sans-serif" font-size="11" fill="#888880">Build an org, not a pipeline.</text>
        </svg>
      </div>
    </div>
  </div>
</section>

<style>
  .feature-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    padding-top: var(--space-2xl);
    margin-bottom: var(--space-xl);
  }

  .feature-heading {
    font-size: clamp(2rem, 4vw, 2.8rem);
    margin-bottom: var(--space-sm);
  }

  .feature-sub {
    color: var(--color-text-muted);
    font-size: 1rem;
    line-height: 1.7;
    max-width: 520px;
  }

  .feature-layout {
    display: grid;
    grid-template-columns: 1fr;
  }

  .graphic-placeholder {
    background: var(--color-surface);
    border-radius: var(--radius-lg);
    min-height: 360px;
    padding: var(--space-md);
  }
</style>
