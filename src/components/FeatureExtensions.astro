---
---

<section class="feature-section section" id="extensions-section">
  <div class="container">
    <hr class="section-divider" />
    <div class="feature-header">
      <div>
        <span class="section-badge">Open Source</span>
        <h2 class="heading-serif feature-heading">Extensible, adaptable,<br />open source.</h2>
        <p class="feature-sub">
          Paperclip is built to be extended. Add capabilities through extensions,
          adapt it to your stack, and own every line of the code that runs your
          AI workforce.
        </p>
      </div>
    </div>

    <!-- Three pillars -->
    <div class="pillars-row">
      <div class="pillar-card" style="--d:0">
        <div class="pillar-icon">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M19.439 7.85c-.049 4.764-1.607 9.326-4.439 12.984-2.832-3.658-4.39-8.22-4.439-12.984h-.001C10.56 4.59 12 2 12 2s1.44 2.59 1.44 5.85h-.001z"/><path d="M11.5 7.85C11.45 4.59 10 2 10 2S7.11 6.85 7.11 12.5c0 3.32.95 6.43 2.59 9.06"/><path d="M12.5 7.85c.05-3.26 1.5-5.85 1.5-5.85s2.89 4.85 2.89 10.5c0 3.32-.95 6.43-2.59 9.06"/></svg>
        </div>
        <span class="pillar-label">Extensible</span>
        <p class="pillar-desc">Drop-in extensions add new capabilities without touching core code.</p>
      </div>
      <div class="pillar-card" style="--d:1">
        <div class="pillar-icon">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 01-2.83 2.83l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 01-4 0v-.09A1.65 1.65 0 009 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 01-2.83-2.83l.06-.06A1.65 1.65 0 004.68 15a1.65 1.65 0 00-1.51-1H3a2 2 0 010-4h.09A1.65 1.65 0 004.6 9a1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 012.83-2.83l.06.06A1.65 1.65 0 009 4.68a1.65 1.65 0 001-1.51V3a2 2 0 014 0v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 012.83 2.83l-.06.06A1.65 1.65 0 0019.4 9a1.65 1.65 0 001.51 1H21a2 2 0 010 4h-.09a1.65 1.65 0 00-1.51 1z"/></svg>
        </div>
        <span class="pillar-label">Adaptable</span>
        <p class="pillar-desc">Works with any LLM provider, any tool stack, any deployment target.</p>
      </div>
      <div class="pillar-card" style="--d:2">
        <div class="pillar-icon">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><line x1="6" y1="3" x2="6" y2="15"/><circle cx="18" cy="6" r="3"/><circle cx="6" cy="18" r="3"/><path d="M18 9a9 9 0 01-9 9"/></svg>
        </div>
        <span class="pillar-label">Open Source</span>
        <p class="pillar-desc">MIT-licensed. Fork it, audit it, contribute back.</p>
      </div>
    </div>

    <!-- Extension grid — commented out until we have real extensions
    <div class="extensions-grid">
      <div class="ext-card" style="--d:3">
        <div class="ext-icon">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M18 8A6 6 0 006 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 01-3.46 0"/></svg>
        </div>
        <span class="ext-name">Slack Alerts</span>
        <p class="ext-desc">Get notified when agents need approval</p>
      </div>
      <div class="ext-card" style="--d:4">
        <div class="ext-icon">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        </div>
        <span class="ext-name">Cost Guardrails</span>
        <p class="ext-desc">Auto-pause agents exceeding budget</p>
      </div>
      <div class="ext-card" style="--d:5">
        <div class="ext-icon">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="18" cy="18" r="3"/><circle cx="6" cy="6" r="3"/><path d="M13 6h3a2 2 0 012 2v7"/><path d="M6 9v12"/></svg>
        </div>
        <span class="ext-name">GitHub Sync</span>
        <p class="ext-desc">Agents open PRs, you review</p>
      </div>
      <div class="ext-card" style="--d:6">
        <div class="ext-icon">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        </div>
        <span class="ext-name">Custom Heartbeats</span>
        <p class="ext-desc">Define your own wake-up schedules</p>
      </div>
      <div class="ext-card" style="--d:7">
        <div class="ext-icon">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M10 13a5 5 0 007.54.54l3-3a5 5 0 00-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 00-7.54-.54l-3 3a5 5 0 007.07 7.07l1.71-1.71"/></svg>
        </div>
        <span class="ext-name">Webhook Bridge</span>
        <p class="ext-desc">Connect Paperclip to anything</p>
      </div>
      <div class="ext-card ext-card--add" style="--d:8">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
        <span class="ext-name">Build Your Own</span>
        <p class="ext-desc">Write an extension in any language</p>
      </div>
    </div>
    -->
  </div>
</section>

<script>
  const section = document.getElementById('extensions-section');
  if (section) {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            section.classList.add('is-visible');
            observer.unobserve(section);
          }
        });
      },
      { threshold: 0.15 }
    );
    observer.observe(section);
  }
</script>

<style>
  .feature-header {
    padding-top: var(--space-2xl);
    margin-bottom: var(--space-xl);
  }

  .feature-heading {
    font-size: clamp(2rem, 4vw, 2.8rem);
    margin-bottom: var(--space-sm);
  }

  .feature-sub {
    color: var(--color-text-muted);
    font-size: 1rem;
    line-height: 1.7;
    max-width: 520px;
  }

  /* ── Three pillars ── */
  .pillars-row {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-md);
  }

  .pillar-card {
    background: var(--color-surface);
    border-radius: var(--radius);
    padding: var(--space-md);
    border: 1.5px solid transparent;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
    opacity: 0;
    transform: translateY(10px);
    transition: opacity 0.4s ease-out, transform 0.4s ease-out, border-color 0.2s ease, box-shadow 0.2s ease;
    transition-delay: calc(var(--d) * 120ms + 100ms);
  }

  #extensions-section:global(.is-visible) .pillar-card {
    opacity: 1;
    transform: translateY(0);
  }

  .pillar-card:hover {
    border-color: #22c55e;
    box-shadow: 0 0 0 1.5px rgba(34, 197, 94, 0.18);
  }

  .pillar-icon {
    color: var(--color-text-muted);
    margin-bottom: var(--space-xs);
  }

  .pillar-label {
    display: block;
    font-weight: 600;
    font-size: 1.05rem;
    margin-bottom: 0.35rem;
  }

  .pillar-desc {
    font-size: 0.88rem;
    color: var(--color-text-muted);
    line-height: 1.55;
  }

  /* ── Extension grid ── */
  .extensions-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-md);
  }

  .ext-card {
    background: var(--color-surface);
    border-radius: var(--radius);
    padding: var(--space-md);
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    border: 1.5px solid transparent;
    transition: opacity 0.4s ease-out, transform 0.4s ease-out, border-color 0.2s ease, box-shadow 0.2s ease;
    transition-delay: calc(var(--d) * 120ms + 100ms);
    opacity: 0;
    transform: translateY(10px);
  }

  #extensions-section:global(.is-visible) .ext-card {
    opacity: 1;
    transform: translateY(0);
  }

  .ext-card:hover {
    border-color: #22c55e;
    box-shadow: 0 0 0 1.5px rgba(34, 197, 94, 0.18);
  }

  .ext-icon {
    color: var(--color-text-muted);
    margin-bottom: 0.15rem;
  }

  .ext-name {
    font-weight: 600;
    font-size: 0.95rem;
  }

  .ext-desc {
    font-size: 0.82rem;
    color: var(--color-text-muted);
    line-height: 1.5;
  }

  /* ── Build Your Own (dashed) ── */
  .ext-card--add {
    border: 2px dashed var(--color-border);
    background: transparent;
    align-items: center;
    justify-content: center;
    text-align: center;
    color: var(--color-text-muted);
  }

  .ext-card--add .ext-name {
    color: var(--color-text-muted);
  }

  .ext-card--add:hover {
    border-color: #22c55e;
    background: transparent;
    box-shadow: none;
  }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .pillars-row {
      grid-template-columns: repeat(2, 1fr);
    }

    .extensions-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 480px) {
    .pillars-row {
      grid-template-columns: 1fr;
    }

    .extensions-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
