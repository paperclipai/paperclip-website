    <div class="navbar-right">
      <a href="/llms.txt" class="navbar-link navbar-link--secondary">llms.txt</a>
      <a href="https://github.com/paperclipai/paperclip" class="navbar-cta">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
        Star{starCount && <span class="navbar-cta-count">{starCount}</span>}
      </a>
    </div>
  </div>
</nav>

<style>
  .navbar {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    padding: 12px 20px 0;
  }

  .navbar-inner {
    display: flex;
    align-items: center;
    justify-content: center;
    height: 76px;
    max-width: 680px;
    margin: 0 auto;
    padding: 0 28px;
    border-radius: 38px;
    background: rgba(7, 11, 23, 0.72);
    backdrop-filter: blur(20px) saturate(1.4);
    -webkit-backdrop-filter: blur(20px) saturate(1.4);
    border: 1px solid rgba(255, 255, 255, 0.14);
    box-shadow:
      0 12px 36px rgba(0, 0, 0, 0.28),
      inset 0 1px 0 rgba(255, 255, 255, 0.16);
  }

  .navbar-left,
  .navbar-right {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    flex: 1;
  }

  .navbar-left {
    justify-content: flex-start;
  }

  .navbar-right {
    justify-content: flex-end;
  }

  .navbar-logo {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    font-weight: 600;
    font-size: 0.95rem;
    color: #fff;
    padding: 0 1.5rem;
    white-space: nowrap;
  }

  .navbar-link {
    font-size: 0.85rem;
    font-weight: 450;
    color: rgba(255, 255, 255, 0.9);
    transition: color 0.2s;
  }

  .navbar-link:hover {
    color: #fff;
  }

  .navbar-link--icon {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
  }

  .navbar-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.8rem;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.96);
    background: rgba(255, 255, 255, 0.08);
    padding: 0.45rem 1rem;
    border-radius: var(--radius-pill);
    border: 1px solid rgba(255, 255, 255, 0.14);
    transition: background 0.2s, color 0.2s;
  }

  .navbar-cta-count {
    font-size: 0.75rem;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.86);
    background: rgba(255, 255, 255, 0.08);
    padding: 0.1rem 0.45rem;
    border-radius: 9999px;
    margin-left: 0.1rem;
  }

  .navbar-cta:hover {
    background: rgba(255, 255, 255, 0.16);
    color: #fff;
  }

  @media (max-width: 768px) {
    .navbar-inner {
      height: 56px;
      padding: 0 20px;
      border-radius: 28px;
      max-width: 100%;
    }

    .navbar-logo {
      padding: 0 1rem;
    }

    .navbar-left,
    .navbar-right {
      gap: 0.75rem;
    }

    .navbar-link {
      font-size: 0.8rem;
    }

    .navbar-cta {
      font-size: 0.75rem;
      padding: 0.35rem 0.75rem;
    }

    .navbar-cta-count {
      font-size: 0.7rem;
      padding: 0.05rem 0.35rem;
    }
  }

  @media (max-width: 480px) {
    .navbar {
      padding: 8px 12px 0;
    }

    .navbar-inner {
      height: 48px;
      padding: 0 14px;
      border-radius: 24px;
    }

    .navbar-logo {
      padding: 0 0.5rem;
      font-size: 0.85rem;
    }

    .navbar-left,
    .navbar-right {
      gap: 0.5rem;
    }

    .navbar-link {
      font-size: 0.75rem;
    }

    /* Hide llms.txt and GitHub link on small mobile to prevent overflow */
    .navbar-link--secondary,
    .navbar-link--icon {
      display: none;
    }

    .navbar-cta {
      font-size: 0.7rem;
      padding: 0.3rem 0.6rem;
      gap: 0.25rem;
    }

    .navbar-cta svg {
      width: 11px;
      height: 11px;
    }

    .navbar-cta-count {
      font-size: 0.65rem;
    }
  }
</style>
