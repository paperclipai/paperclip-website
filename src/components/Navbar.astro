---

<nav class="navbar">
  <div class="navbar-inner">
    <a href="/" class="navbar-logo">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M9 2a5 5 0 0 1 5 5v12a3 3 0 0 1-6 0V7a1 1 0 0 1 2 0v10" />
      </svg>
      <span>Paperclip</span>
    </a>
    <div class="navbar-links">
      <a href="https://github.com/paperclip-ai/paperclip" class="navbar-link">Docs</a>
      <a href="https://github.com/paperclip-ai/paperclip" class="navbar-link">GitHub</a>
      <a href="https://github.com/paperclip-ai/paperclip" class="navbar-cta">
        Star on GitHub
      </a>
    </div>
  </div>
</nav>

<style>
  .navbar {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(255, 255, 255, 0.9);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--color-border);
  }

  .navbar-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.9rem var(--space-md);
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .navbar-logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-weight: 600;
    font-size: 0.95rem;
    color: var(--color-text);
  }

  .navbar-links {
    display: flex;
    align-items: center;
    gap: 1.75rem;
  }

  .navbar-link {
    font-size: 0.9rem;
    color: var(--color-text-secondary);
    transition: color 0.2s;
  }

  .navbar-link:hover {
    color: var(--color-text);
  }

  .navbar-cta {
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--color-bg);
    background: var(--color-text);
    padding: 0.5rem 1.1rem;
    border-radius: var(--radius-pill);
    transition: opacity 0.2s;
  }

  .navbar-cta:hover {
    opacity: 0.85;
  }

  @media (max-width: 480px) {
    .navbar-cta {
      display: none;
    }
  }
</style>
