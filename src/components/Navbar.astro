<style>
  .navbar {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    padding: 12px 20px 0;
  }

  .navbar-inner {
    display: flex;
    align-items: center;
    justify-content: center;
    height: 76px;
    max-width: 680px;
    margin: 0 auto;
    padding: 0 28px;
    border-radius: 38px;
    background: rgba(255, 255, 255, 0.12);
    backdrop-filter: blur(20px) saturate(1.4);
    -webkit-backdrop-filter: blur(20px) saturate(1.4);
    border: 1px solid rgba(255, 255, 255, 0.2);
    box-shadow:
      0 2px 16px rgba(0, 0, 0, 0.08),
      inset 0 1px 0 rgba(255, 255, 255, 0.25);
  }

  .navbar-left,
  .navbar-right {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    flex: 1;
  }

  .navbar-left {
    justify-content: flex-start;
  }

  .navbar-right {
    justify-content: flex-end;
  }

  .navbar-logo {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    font-weight: 600;
    font-size: 0.95rem;
    color: #fff;
    padding: 0 1.5rem;
    white-space: nowrap;
  }

  .navbar-link {
    font-size: 0.85rem;
    font-weight: 450;
    color: rgba(255, 255, 255, 0.8);
    transition: color 0.2s;
  }

  .navbar-link:hover {
    color: #fff;
  }

  .navbar-link--icon {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
  }

  .navbar-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.8rem;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.9);
    background: rgba(255, 255, 255, 0.12);
    padding: 0.45rem 1rem;
    border-radius: var(--radius-pill);
    border: 1px solid rgba(255, 255, 255, 0.15);
    transition: background 0.2s, color 0.2s;
  }

  .navbar-cta:hover {
    background: rgba(255, 255, 255, 0.2);
    color: #fff;
  }

  @media (max-width: 768px) {
    .navbar-inner {
      height: 60px;
      padding: 0 20px;
      border-radius: 30px;
      max-width: 100%;
    }

    .navbar-logo {
      padding: 0 1rem;
    }
  }

  @media (max-width: 480px) {
    .navbar {
      padding: 8px 12px 0;
    }

    .navbar-inner {
      height: 52px;
      padding: 0 16px;
      border-radius: 26px;
    }

    .navbar-logo {
      padding: 0 0.6rem;
      font-size: 0.88rem;
    }

    .navbar-left,
    .navbar-right {
      gap: 0.75rem;
    }

    .navbar-link {
      font-size: 0.8rem;
    }

    .navbar-cta svg {
      display: none;
    }
  }
</style>
