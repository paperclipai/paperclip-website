---
---

<section class="hero">
  <div class="container hero-inner">
    <h1 class="hero-headline heading-serif">
      Paperclip runs<br />your business.
    </h1>
    <p class="hero-sub">
      Manage a team of AI agents to run your business.
    </p>
    <p class="hero-lede">
      Paperclip lets you stand up an organization of agents — with org structure,
      budgets, governance, and goals. Define what your company does. Hire the agents
      to do it. You stay in control, they execute.
    </p>
    <div class="hero-actions">
      <a href="#get-started" class="hero-btn-primary">Get started</a>
      <a href="https://github.com/paperclip-ai/paperclip" class="hero-btn-secondary">
        GitHub
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7"/><path d="M7 7h10v10"/></svg>
      </a>
    </div>
  </div>
</section>

<style>
  .hero {
    padding: var(--space-3xl) 0 var(--space-2xl);
    text-align: center;
  }

  .hero-inner {
    max-width: 780px;
  }

  .hero-headline {
    font-size: clamp(3.2rem, 8vw, 5rem);
    margin-bottom: var(--space-md);
  }

  .hero-sub {
    font-size: clamp(1.1rem, 2.5vw, 1.3rem);
    color: var(--color-text-secondary);
    margin-bottom: var(--space-sm);
  }

  .hero-lede {
    font-size: 1.05rem;
    color: var(--color-text-muted);
    max-width: 560px;
    margin: 0 auto var(--space-lg);
    line-height: 1.7;
  }

  .hero-actions {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-sm);
    flex-wrap: wrap;
  }

  .hero-btn-primary {
    display: inline-block;
    font-size: 0.95rem;
    font-weight: 500;
    padding: 0.8rem 2rem;
    background: var(--color-text);
    color: var(--color-bg);
    border-radius: var(--radius-pill);
    transition: opacity 0.2s;
  }

  .hero-btn-primary:hover {
    opacity: 0.85;
  }

  .hero-btn-secondary {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.95rem;
    padding: 0.8rem 2rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-pill);
    color: var(--color-text-secondary);
    transition: color 0.2s, border-color 0.2s;
  }

  .hero-btn-secondary:hover {
    color: var(--color-text);
    border-color: var(--color-text-muted);
  }
</style>
