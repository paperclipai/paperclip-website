---
const items = [
  {
    label: 'An org chart for agents.',
    detail: 'Hierarchies, roles, reporting lines. Your agents don\u2019t freelance \u2014 they have a boss, a title, and a job description.',
  },
  {
    label: 'A governance layer.',
    detail: 'You sit at the top. Approve hires, review strategy, override decisions. Agents work for you, not the other way around.',
  },
  {
    label: 'A cost control system.',
    detail: 'Every agent has a budget. Every tool call has a price. You see where money goes before it\u2019s gone.',
  },
  {
    label: 'Full observability.',
    detail: 'Every ticket traced. Every decision explained. Every tool call logged. Nothing happens in the dark.',
  },
  {
    label: 'A multi-company runtime.',
    detail: 'Run one AI company or run fifty. Complete isolation between businesses. One install, one control plane, unlimited companies.',
  },
];
---

<section class="what-is-section section">
  <div class="container">
    <hr class="section-divider" />
    <div class="what-is-header">
      <span class="section-badge">Identity</span>
      <h2 class="heading-serif what-is-heading">What Paperclip is.</h2>
    </div>
    <div class="what-is-grid">
      {items.map((item, i) => (
        <div class:list={['what-is-item', i === 4 && 'what-is-item-wide']}>
          <h3 class="what-is-label">{item.label}</h3>
          <p class="what-is-detail">{item.detail}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .what-is-header {
    padding-top: var(--space-2xl);
    margin-bottom: var(--space-xl);
  }

  .what-is-heading {
    font-size: clamp(2rem, 4vw, 2.8rem);
  }

  .what-is-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: var(--color-border);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    overflow: hidden;
  }

  .what-is-item {
    background: var(--color-bg);
    padding: var(--space-lg) var(--space-md);
  }

  .what-is-item-wide {
    grid-column: span 2;
  }

  .what-is-label {
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: 1.05rem;
    margin-bottom: 0.4rem;
  }

  .what-is-detail {
    color: var(--color-text-muted);
    font-size: 0.93rem;
    line-height: 1.6;
  }

  @media (max-width: 768px) {
    .what-is-grid {
      grid-template-columns: 1fr;
    }

    .what-is-item-wide {
      grid-column: span 1;
    }
  }
</style>
