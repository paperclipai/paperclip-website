---
---

<section class="feature-section section">
  <div class="container">
    <hr class="section-divider" />
    <div class="feature-header">
      <div>
        <span class="section-badge">Multi-Company</span>
        <h2 class="heading-serif feature-heading">One deployment.<br />Many companies.</h2>
        <p class="feature-sub">
          Paperclip supports multiple businesses in one install. Run one AI company
          or run fifty. Complete data isolation between companies. One control plane
          for your entire portfolio.
        </p>
      </div>
    </div>
    <div class="feature-layout">
      <div class="companies-grid">

        <!-- Card 1: Mobile Marketing Co -->
        <div class="company-card-wrapper">
          <div class="company-card" data-company="marketing">
            <div class="company-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="5" y="2" width="14" height="20" rx="2"/><circle cx="12" cy="18" r="1"/><line x1="9" y1="5" x2="15" y2="5"/></svg>
            </div>
            <span class="company-name">Mobile Marketing Co</span>
            <span class="company-agents">8 agents</span>
            <span class="company-status active">Active</span>
          </div>
          <div class="org-dropdown" data-tree="marketing">
            <div class="org-tree-mini">
              <div class="mini-row mini-row--single">
                <div class="mini-card" style="--d:0">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                  <span>CEO</span>
                </div>
              </div>
              <div class="mini-stem" style="--d:1"></div>
              <div class="mini-row mini-row--cols-2">
                <div class="mini-card" style="--d:2">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>
                  <span>VP Marketing</span>
                </div>
                <div class="mini-card" style="--d:3">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>
                  <span>VP Growth</span>
                </div>
              </div>
              <div class="mini-stem" style="--d:4"></div>
              <div class="mini-row mini-row--cols-4">
                <div class="mini-card" style="--d:5">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 013 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
                  <span>Content</span>
                </div>
                <div class="mini-card" style="--d:6">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
                  <span>Ads</span>
                </div>
                <div class="mini-card" style="--d:7">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
                  <span>SEO</span>
                </div>
                <div class="mini-card" style="--d:8">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>
                  <span>Analytics</span>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Card 2: John Street Hyperliquid Fund -->
        <div class="company-card-wrapper">
          <div class="company-card" data-company="fund">
            <div class="company-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>
            </div>
            <span class="company-name">John Street Hyperliquid Fund</span>
