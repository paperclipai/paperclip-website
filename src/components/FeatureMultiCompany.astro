<script>
  document.querySelectorAll('.company-card[data-company]').forEach(card => {
    const wrapper = card.closest('.company-card-wrapper');
    const dropdown = wrapper.querySelector('.org-dropdown');
    if (!dropdown) return;

    let hideTimeout;

    function show() {
      clearTimeout(hideTimeout);
      document.querySelectorAll('.org-dropdown.is-open').forEach(d => {
        if (d !== dropdown) close(d);
      });
      dropdown.classList.add('is-open');
      const cards = dropdown.querySelectorAll('.mini-card');
      cards.forEach(c => c.classList.remove('is-visible'));
      requestAnimationFrame(() => {
        cards.forEach(c => c.classList.add('is-visible'));
      });
    }

    function close(d) {
      d.classList.remove('is-open');
      d.querySelectorAll('.mini-card').forEach(c => c.classList.remove('is-visible'));
    }

    function hide() {
      hideTimeout = setTimeout(() => close(dropdown), 200);
    }

    card.addEventListener('mouseenter', show);
    card.addEventListener('mouseleave', hide);
    dropdown.addEventListener('mouseenter', () => clearTimeout(hideTimeout));
    dropdown.addEventListener('mouseleave', hide);
  });
</script>

<style>
  .feature-header {
    padding-top: var(--space-2xl);
    margin-bottom: var(--space-xl);
  }

  .feature-heading {
    font-size: clamp(2rem, 4vw, 2.8rem);
    margin-bottom: var(--space-sm);
  }

  .feature-sub {
    color: var(--color-text-muted);
    font-size: 1rem;
    line-height: 1.7;
    max-width: 520px;
  }

  .companies-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-md);
    align-items: start;
  }

  .company-card-wrapper {
    position: relative;
  }

  .company-card {
    background: var(--color-surface);
    border-radius: var(--radius);
    padding: var(--space-md);
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    cursor: default;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
    border: 1.5px solid transparent;
  }

  .company-card[data-company]:hover {
    border-color: #22c55e;
    box-shadow: 0 0 0 1.5px rgba(34, 197, 94, 0.18);
  }

  .company-icon {
    color: var(--color-text-muted);
    margin-bottom: 0.25rem;
  }

  .company-name {
    font-weight: 600;
    font-size: 0.95rem;
    line-height: 1.25;
    min-height: 2.5em;
    display: flex;
    align-items: flex-start;
  }

  .company-agents {
    font-size: 0.8rem;
    color: var(--color-text-muted);
  }

  .company-status {
    font-size: 0.75rem;
    font-weight: 500;
    padding: 0.2em 0.6em;
    border-radius: var(--radius-pill);
    width: fit-content;
  }

  .company-status.active {
    background: #dcfce7;
    color: #166534;
  }

  .card-add {
    border: 2px dashed var(--color-border);
    background: transparent;
    align-items: center;
    justify-content: center;
    color: var(--color-text-muted);
    /* match height of sibling cards */
  }

  .card-add .company-name {
    min-height: auto;
    justify-content: center;
  }

  /* ── Org tree dropdown ── */
  .org-dropdown {
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%);
    z-index: 20;
    width: max-content;
    min-width: 100%;
    max-width: 340px;
    padding-top: 6px;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.2s ease;
  }

  .org-dropdown:global(.is-open) {
    pointer-events: auto;
    opacity: 1;
  }

  .org-tree-mini {
    background: var(--color-bg);
    border: 1.5px solid var(--color-border);
    border-radius: var(--radius-sm);
    padding: 16px 14px;
    box-shadow: 0 8px 32px rgba(0,0,0,0.10), 0 2px 8px rgba(0,0,0,0.06);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
  }

  /* ── Mini rows ── */
  .mini-row {
    width: 100%;
    position: relative;
  }

  .mini-row--single {
    display: flex;
    justify-content: center;
  }

  /* ── Grid-based multi-child rows ── */
  /* Each column count gets its own class so the horizontal bar
     lines up exactly from the center of the first cell to the
     center of the last cell.
     Formula: inset = (100% - (N-1) * gap) / (2 * N)           */

  .mini-row--cols-2 {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 6px;
    padding-top: 16px;
  }

  .mini-row--cols-3 {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 6px;
    padding-top: 16px;
  }

  .mini-row--cols-4 {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 6px;
    padding-top: 16px;
  }

  /* Horizontal connection bar */
  .mini-row--cols-2::before,
  .mini-row--cols-3::before,
  .mini-row--cols-4::before {
    content: '';
    position: absolute;
    top: 0;
    height: 1.5px;
    background: #b5b0a8;
    opacity: 0;
    transition: opacity 0.3s ease 0.15s;
  }

  /* 2 cols: inset = (100% - 6px) / 4 */
  .mini-row--cols-2::before {
    left: calc((100% - 6px) / 4);
    right: calc((100% - 6px) / 4);
  }

  /* 3 cols: inset = (100% - 12px) / 6 */
  .mini-row--cols-3::before {
    left: calc((100% - 12px) / 6);
    right: calc((100% - 12px) / 6);
  }

  /* 4 cols: inset = (100% - 18px) / 8 */
  .mini-row--cols-4::before {
    left: calc((100% - 18px) / 8);
    right: calc((100% - 18px) / 8);
  }

  .org-dropdown:global(.is-open) .mini-row--cols-2::before,
  .org-dropdown:global(.is-open) .mini-row--cols-3::before,
  .org-dropdown:global(.is-open) .mini-row--cols-4::before {
    opacity: 1;
  }

  /* Drop lines from horizontal bar down into each card */
  .mini-row--cols-2 > .mini-card::before,
  .mini-row--cols-3 > .mini-card::before,
  .mini-row--cols-4 > .mini-card::before {
    content: '';
    position: absolute;
    top: -16px;
    left: 50%;
    transform: translateX(-50%);
    width: 1.5px;
    height: 16px;
    background: #b5b0a8;
    opacity: 0;
    transition: opacity 0.3s ease 0.15s;
  }

  .org-dropdown:global(.is-open) .mini-row--cols-2 > .mini-card::before,
  .org-dropdown:global(.is-open) .mini-row--cols-3 > .mini-card::before,
  .org-dropdown:global(.is-open) .mini-row--cols-4 > .mini-card::before {
    opacity: 1;
  }

  /* Vertical stem between levels */
  .mini-stem {
    width: 1.5px;
    height: 16px;
    background: #b5b0a8;
    opacity: 0;
    transition: opacity 0.3s ease 0.1s;
  }

  .org-dropdown:global(.is-open) .mini-stem {
    opacity: 1;
  }

  /* ── Mini card ── */
  .mini-card {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 4px;
    padding: 5px 8px;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 6px;
    white-space: nowrap;
    opacity: 0;
    transform: translateY(6px);
    transition: opacity 0.3s ease, transform 0.3s ease, border-color 0.3s ease;
    transition-delay: calc(var(--d) * 60ms);
  }

  .mini-card:global(.is-visible) {
    opacity: 1;
    transform: translateY(0);
  }

  .mini-card svg {
    flex-shrink: 0;
    color: var(--color-text-muted);
  }

  .mini-card span {
    font-size: 0.65rem;
    font-weight: 500;
    color: var(--color-text-secondary);
    line-height: 1;
  }

  /* Ghost cards for "Add company" */
