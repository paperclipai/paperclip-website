---
import Terminal from './Terminal.astro';
---

<section class="quickstart section">
  <div class="container quickstart-inner">
    <div class="quickstart-left">
      <h2 class="heading-serif quickstart-heading">Quickstart</h2>
      <p class="quickstart-sub">
        Open source. Self-hosted. Interactive setup walks you through database, auth,
        and your first company. No Paperclip account required.
      </p>
      <div class="quickstart-links">
        <a href="https://github.com/paperclip-ai/paperclip" class="quickstart-btn">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
          Star on GitHub
        </a>
        <a href="https://github.com/paperclip-ai/paperclip" class="quickstart-link">Read the docs &rarr;</a>
      </div>
    </div>
    <div class="quickstart-right">
      <Terminal />
    </div>
  </div>
</section>

<style>
  .quickstart-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-xl);
    align-items: center;
  }

  .quickstart-left {
    text-align: left;
  }

  .quickstart-heading {
    font-size: clamp(2rem, 4vw, 2.8rem);
    margin-bottom: var(--space-sm);
  }

  .quickstart-sub {
    color: var(--color-text-muted);
    font-size: 1rem;
    line-height: 1.7;
    margin-bottom: var(--space-lg);
  }

  .quickstart-links {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    flex-wrap: wrap;
  }

  .quickstart-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--color-bg);
    background: var(--color-text);
    padding: 0.6rem 1.3rem;
    border-radius: var(--radius-pill);
    transition: opacity 0.2s;
  }

  .quickstart-btn:hover {
    opacity: 0.85;
  }

  .quickstart-link {
    font-size: 0.95rem;
    color: var(--color-text-secondary);
    transition: color 0.2s;
  }

  .quickstart-link:hover {
    color: var(--color-text);
  }

  @media (max-width: 768px) {
    .quickstart-inner {
      grid-template-columns: 1fr;
      gap: var(--space-lg);
    }

    .quickstart-left {
      text-align: center;
    }

    .quickstart-links {
      justify-content: center;
    }
  }
</style>
