# Paperclip VPS deploy — environment template.
# Copy to /opt/paperclip/docker/.env, fill in values, then run:
#
#   docker compose -f docker-compose.yml -f docker-compose.prod.yml up -d
#
# The bootstrap.sh script generates this file for you with sensible defaults
# and random secrets.

# ---- Required ----------------------------------------------------------------

# The HTTPS hostname Paperclip is reachable at. Must resolve via DNS to this VPS
# before bringing up the stack — Caddy acquires the Let's Encrypt cert on first
# request and will fail closed without working DNS.
PAPERCLIP_DOMAIN=paperclip.example.com

# Public origin for cookies, CSRF, OAuth callbacks. Must use https:// and match
# PAPERCLIP_DOMAIN. Setting this to a bare IP or http:// breaks login the second
# time. See the W9.1 blog post, "Three things you'll get wrong" #2.
PAPERCLIP_PUBLIC_URL=https://paperclip.example.com

# 32-byte random hex. Rotating this invalidates every session and breaks any
# in-flight CSRF tokens — generate once and keep.
#   openssl rand -hex 32
BETTER_AUTH_SECRET=

# Postgres password. Random per install. Postgres is bound to the docker
# network only (see docker-compose.prod.yml) so this is defense-in-depth.
#   openssl rand -hex 24
POSTGRES_PASSWORD=

# ---- Pinned versions ---------------------------------------------------------

# Paperclip git ref the bootstrap script clones. Pinned per-release so you can
# rebuild deterministically. Bumping this is a deploy.
PAPERCLIP_REF=v2026.427.0

# Postgres image tag. Pinned to a specific minor; bumping the major requires a
# pg_dump/pg_restore cycle.
POSTGRES_IMAGE=postgres:17.4-alpine

# Caddy image tag. 2.8.x is the line we test against.
CADDY_IMAGE=caddy:2.8
